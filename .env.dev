# ═══════════════════════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════════════════════
SERVER_PORT=8086
APP_TIMEZONE=Asia/Ho_Chi_Minh

# ═══════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════
DB_URL= jdbc:mysql://100.102.72.31:3306/event_app?allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=root
DB_PASSWORD=1234567890
DB_POOL_SIZE=10
DB_MIN_IDLE=2

# ═══════════════════════════════════════════════════════════════
# JPA
# ═══════════════════════════════════════════════════════════════
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=true

# ═══════════════════════════════════════════════════════════════
# JWT  (QUAN TRONG: doi secret truoc khi deploy)
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=SuperLongSecretKeyHereAtLeast32CharactersMakeItRandom2026
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ═══════════════════════════════════════════════════════════════
# UPLOAD
# ═══════════════════════════════════════════════════════════════
UPLOAD_AVATAR_DIR=uploads/avatars
UPLOAD_MAX_FILE_SIZE=5MB
UPLOAD_MAX_REQUEST_SIZE=6MB

# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_SQL=WARN
LOG_FILE=logs/event-app-dev.log

# ═══════════════════════════════════════════════════════════════
# ACTUATOR
# ═══════════════════════════════════════════════════════════════
ACTUATOR_ENDPOINTS=health,info

# ═══════════════════════════════════════════════════════════════
# SCHEDULING
# ═══════════════════════════════════════════════════════════════
SCHEDULER_POOL_SIZE=2
