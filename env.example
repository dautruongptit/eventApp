# Copy file nay thanh .env va dien gia tri thuc te
# cp .env.example .env

SERVER_PORT=8080
APP_TIMEZONE=Asia/Ho_Chi_Minh

DB_URL=jdbc:mysql://localhost:3306/nhac_su_kien?useSSL=false&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MIN_IDLE=2

JPA_DDL_AUTO=validate
JPA_SHOW_SQL=true

# REQUIRED: Generate bang: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

UPLOAD_AVATAR_DIR=uploads/avatars
UPLOAD_MAX_FILE_SIZE=5MB
UPLOAD_MAX_REQUEST_SIZE=6MB

LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_SQL=WARN

# ═══════════════════════════════════════════════════════════════
# ACTUATOR
# ═══════════════════════════════════════════════════════════════
ACTUATOR_ENDPOINTS=health,info

# ═══════════════════════════════════════════════════════════════
# SCHEDULING
# ═══════════════════════════════════════════════════════════════
SCHEDULER_POOL_SIZE=2
